# Guesty API Configuration
# Get these from your Guesty account at https://guesty.com/integrations/api

# Booking Engine API (BEAPI) - For guest-facing operations
GUESTY_BE_CLIENT_ID=your_be_client_id_here
GUESTY_BE_CLIENT_SECRET=your_be_client_secret_here

# Open API (OAPI) - For operations, webhooks, and admin features
GUESTY_OPEN_API_CLIENT_ID=your_open_api_client_id_here
GUESTY_OPEN_API_CLIENT_SECRET=your_open_api_client_secret_here

# Booking Type Configuration
# Set to 'INQUIRY' for manual approval bookings or 'INSTANT' for immediate bookings
GUESTY_BOOKING_TYPE=INQUIRY

# Webhook Security
# Generate a secure random string for webhook signature verification
GUESTY_WEBHOOK_SECRET=your_webhook_secret_here

# Application Configuration
# Comma-separated list of allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Supabase Configuration (if using Supabase for additional features)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Sentry Error Tracking (optional)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Clerk Authentication (optional - replace with simple auth if preferred)
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
